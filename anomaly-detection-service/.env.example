# ============================================================
# 异常检测服务配置
# ============================================================

# 应用配置
APP_NAME=NetData Anomaly Detection Service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# 服务配置
HOST=0.0.0.0
PORT=8001

# NetData 配置
NETDATA_HOST=localhost
NETDATA_PORT=19999
NETDATA_TIMEOUT=10.0

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ops_user
MYSQL_PASSWORD=ops123456
MYSQL_DATABASE=netdata_ops

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123456
REDIS_DB=0

# 检测器配置
DEFAULT_DETECTOR=isolation_forest
ANOMALY_THRESHOLD=0.7
ALERT_THRESHOLD=0.85

# 日志配置
LOG_LEVEL=INFO
