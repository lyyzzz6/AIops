# ============================================================
# 智能运维问答与执行系统 - 环境变量配置
# ============================================================
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改以下配置项（特别是密码！）
# 3. 运行 docker-compose up -d
#
# 安全提示：
# - 生产环境务必修改所有默认密码
# - .env 文件不要提交到 Git（已在 .gitignore 中配置）
# - 敏感信息使用 Docker secrets 或环境变量注入
#
# 作者：刘一舟
# 更新时间：2026-04-03
# ============================================================

# ============================================================
# MySQL 配置
# ============================================================
# 端口配置（避免端口冲突时可修改）
MYSQL_PORT=3306

# root 用户密码（生产环境必须修改！）
MYSQL_ROOT_PASSWORD=root123456

# 业务数据库配置
MYSQL_DATABASE=netdata_ops
MYSQL_USER=ops_user
MYSQL_PASSWORD=ops123456

# 数据持久化路径（Windows 使用 / 或 \\ 作为分隔符）
MYSQL_DATA_PATH=./data/mysql

# ============================================================
# Redis 配置
# ============================================================
REDIS_PORT=6379

# Redis 密码（生产环境必须修改！）
REDIS_PASSWORD=redis123456

# 数据持久化路径
REDIS_DATA_PATH=./data/redis

# ============================================================
# Milvus 向量数据库配置
# ============================================================
# gRPC 端口（SDK 连接）
MILVUS_GRPC_PORT=19530
# Metrics 端口（Prometheus 监控）
MILVUS_METRICS_PORT=9091

# 数据持久化路径
MILVUS_DATA_PATH=./data/milvus

# ============================================================
# MinIO 配置（Milvus 底层存储）
# ============================================================
# MinIO 凭证（生产环境必须修改！）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================
# Ollama 配置
# ============================================================
OLLAMA_PORT=11434

# 数据持久化路径（存储模型文件，占用空间大）
OLLAMA_DATA_PATH=./data/ollama

# ============================================================
# 异常检测服务（anomaly-detection-service）
# ============================================================
# 运行模式：production / development
ANOMALY_ENV=production
ANOMALY_DEBUG=false

# 对外暴露端口（默认 8001，冲突时修改）
ANOMALY_PORT=8001

# NetData 指标源
# - 默认 host.docker.internal 连宿主机 NetData Agent
# - 若 NetData 也跑在容器内，改成对应 compose 服务名
NETDATA_HOST=host.docker.internal
NETDATA_PORT=19999
NETDATA_TIMEOUT=10.0

# 检测器默认参数
DEFAULT_DETECTOR=isolation_forest
ANOMALY_THRESHOLD=0.7
ALERT_THRESHOLD=0.85

# 日志与模型持久化路径
ANOMALY_LOGS_PATH=./logs/anomaly
ANOMALY_MODELS_PATH=./data/anomaly_models

# ============================================================
# Neo4j 配置（可选，知识图谱功能）
# ============================================================
# NEO4J_PASSWORD=neo4j123456
# NEO4J_DATA_PATH=./data/neo4j

# ============================================================
# DeepSeek API 配置（生产环境主用）
# ============================================================
# DeepSeek API Key（从 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ============================================================
# Spring Profile 配置
# ============================================================
# 开发环境使用 ollama，生产环境使用 deepseek
SPRING_PROFILES_ACTIVE=dev

# ============================================================
# 日志级别
# ============================================================
LOG_LEVEL=info

# ============================================================
# 开发调试配置
# ============================================================
# 是否开启调试模式（开启后会输出更多日志）
DEBUG_MODE=false

# JVM 调试端口（远程调试用）
DEBUG_PORT=5005

# ============================================================
# Frontend 配置
# ============================================================
FRONTEND_PORT=3000

# ============================================================
# Mock Netdata 配置
# ============================================================
MOCK_NETDATA_PORT=19998

# ============================================================
# Backend 配置
# ============================================================
BACKEND_PORT=8080
