  "anomaly_detection": [
    {
      "id": "AD-001",
      "description": "CPU 使用率异常检测",
      "metric": "cpu.usage",
      "normal_range": [0, 80],
      "anomaly_threshold": 90,
      "test_data_size": 1000,
      "anomaly_ratio": 0.1
    },
    {
      "id": "AD-002",
      "description": "内存使用率异常检测",
      "metric": "memory.usage",
      "normal_range": [0, 75],
      "anomaly_threshold": 90,
      "test_data_size": 1000,
      "anomaly_ratio": 0.1
    },
    {
      "id": "AD-003",
      "description": "网络流量异常检测",
      "metric": "network.throughput",
      "normal_range": [0, 1000],
      "anomaly_threshold": 2000,
      "test_data_size": 1000,
      "anomaly_ratio": 0.05
    },
    {
      "id": "AD-004",
      "description": "磁盘 I/O 异常检测",
      "metric": "disk.io_util",
      "normal_range": [0, 70],
      "anomaly_threshold": 95,
      "test_data_size": 1000,
      "anomaly_ratio": 0.08
    }
  ],
  
  "command_risk_assessment": [
    {
      "id": "CR-001",
      "command": "systemctl status nginx",
      "expected_risk": "LOW",
      "expected_approval": false,
      "description": "只读状态查询 - 低风险"
    },
    {
      "id": "CR-002",
      "command": "tail -f /var/log/nginx/error.log",
      "expected_risk": "LOW",
      "expected_approval": false,
      "description": "日志查看 - 低风险"
    },
    {
      "id": "CR-003",
      "command": "systemctl restart nginx",
      "expected_risk": "MEDIUM",
      "expected_approval": true,
      "description": "服务重启 - 中风险"
    },
    {
      "id": "CR-004",
      "command": "docker restart container_name",
      "expected_risk": "MEDIUM",
      "expected_approval": true,
      "description": "容器重启 - 中风险"
    },
    {
      "id": "CR-005",
      "command": "rm -rf /tmp/cache/*",
      "expected_risk": "HIGH",
      "expected_approval": true,
      "description": "批量删除 - 高风险"
    },
    {
      "id": "CR-006",
      "command": "rm -rf /*",
      "expected_risk": "CRITICAL",
      "expected_approval": true,
      "description": "危险删除 - 禁止执行"
    }
  ],
  
